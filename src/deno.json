{
  "unstable": ["kv"],
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "test": "deno test -A --no-check",
    "test:check": "deno check main.ts mcp/main.ts && deno test -A --no-check",
    "mcp": "deno run -A mcp/main.ts"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.2.2",
    "preact": "npm:preact@^10.27.2",
    "@preact/signals": "npm:@preact/signals@^2.5.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "@std/yaml": "jsr:@std/yaml@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/testing/bdd": "jsr:@std/testing@^1/bdd",
    "zod": "npm:zod@^3.24",
    "@modelcontextprotocol/sdk": "npm:@modelcontextprotocol/sdk@^1",
    "@modelcontextprotocol/sdk/server/mcp": "npm:@modelcontextprotocol/sdk@^1/server/mcp.js",
    "@modelcontextprotocol/sdk/server/stdio": "npm:@modelcontextprotocol/sdk@^1/server/stdio.js",
    "@modelcontextprotocol/sdk/client/index.js": "npm:@modelcontextprotocol/sdk@^1/client",
    "@modelcontextprotocol/sdk/inMemory.js": "npm:@modelcontextprotocol/sdk@^1/inMemory.js",
    "@scrim/core": "../../scrim/packages/core/mod.ts",
    "@scrim/core/types": "../../scrim/packages/core/src/types/mod.ts",
    "@scrim/core/runtime": "../../scrim/packages/core/src/runtime/mod.ts",
    "@scrim/core/context": "../../scrim/packages/core/src/context/mod.ts",
    "@scrim/schema": "../../scrim/packages/schema/mod.ts",
    "@scrim/validate": "../../scrim/packages/validate/mod.ts",
    "@scrim/web": "../../scrim/packages/web/mod.ts",
    "@scrim/assessment": "../../scrim/packages/assessment/mod.ts",
    "@preact/signals-core": "npm:@preact/signals-core@^1.8.0"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
